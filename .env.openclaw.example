SUPABASE_URL="https://ciaxfxuqucidzqbdgydg.supabase.co"
OPENCLAW_SERVICE_TOKEN="replace_with_supabase_secret_OPENCLAW_SERVICE_TOKEN"

# Worker identity
OPENCLAW_WORKER_ID="openclaw-laptop-1"

# Safety + scheduling
OPENCLAW_POLL_INTERVAL_MS="3600000"    # 1 hour
OPENCLAW_MAX_JOBS_PER_CYCLE="3"
OPENCLAW_REQUEST_TIMEOUT_MS="20000"
OPENCLAW_ENQUEUE_ENABLED="true"
